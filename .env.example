# AI Content Repurposing Studio - Environment Variables
# Copy this file to .env.local and fill in your values

# App Configuration
VITE_APP_NAME=AI Content Repurposing Studio
VITE_APP_URL=http://localhost:5173

# AI Provider Selection (groq, gemini, openrouter, deepseek)
VITE_API_PROVIDER=groq

# API Keys (depending on provider)
VITE_GROQ_API_KEY=your_groq_api_key_here
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here
VITE_DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Optional: API Endpoints (for custom deployments)
# VITE_GROQ_API_URL=https://api.groq.com/openai/v1
# VITE_GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta
# VITE_OPENROUTER_API_URL=https://openrouter.ai/api/v1

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_REPORTING=false
